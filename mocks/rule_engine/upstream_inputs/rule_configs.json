{
  "version": "v1",
  "ai_gate": {
    "invoke_on_unknown": true,
    "invoke_on_action_with_deadline": true,
    "invoke_on_high_risk": true,
    "skip_on_irrelevant": true
  },
  "thresholds": {
    "relevant_score": 0.7,
    "unknown_score": 0.35,
    "source_bonus_high": 0.1,
    "source_bonus_medium": 0.05,
    "source_bonus_low": 0.0
  },
  "rules": [
    {
      "rule_id": "rule_grad_identity",
      "rule_name": "毕业生身份标签匹配",
      "scene": "rule_engine",
      "enabled": true,
      "priority": 100,
      "conditions": {
        "all_keywords": ["毕业生"],
        "profile_any": {
          "identity_tags": ["毕业生"],
          "graduation_stage": ["graduation_review", "graduation_application"]
        }
      },
      "outputs": {
        "dimension": "audience",
        "hit_type": "profile_match",
        "weight": 0.45,
        "candidate_categories": ["graduation"],
        "required_profile_facets": ["identity_core", "graduation_progress"],
        "signals": {
          "audience": ["毕业生"]
        },
        "explanation": "命中毕业生身份标签",
        "emit_match": false
      },
      "version": "v1"
    },
    {
      "rule_id": "rule_grad_001",
      "rule_name": "毕业生材料提交识别",
      "scene": "rule_engine",
      "enabled": true,
      "priority": 90,
      "conditions": {
        "all_keywords": ["提交", "材料"],
        "any_keywords": ["毕业生"],
        "action_keywords": ["提交", "审核材料"]
      },
      "outputs": {
        "dimension": "action",
        "hit_type": "keyword",
        "weight": 0.2,
        "candidate_categories": ["material_submission"],
        "action_required": true,
        "signals": {
          "action_keywords": ["提交", "审核材料"]
        },
        "explanation": "命中材料提交动作",
        "emit_match": true
      },
      "version": "v1"
    },
    {
      "rule_id": "rule_explicit_deadline",
      "rule_name": "明确截止时间识别",
      "scene": "rule_engine",
      "enabled": true,
      "priority": 80,
      "conditions": {
        "requires_deadline": true
      },
      "outputs": {
        "dimension": "deadline",
        "hit_type": "regex",
        "weight": 0.1,
        "explanation": "存在明确截止时间",
        "emit_match": false
      },
      "version": "v1"
    },
    {
      "rule_id": "rule_graduation_high_risk",
      "rule_name": "毕业审核高风险场景",
      "scene": "rule_engine",
      "enabled": true,
      "priority": 70,
      "conditions": {
        "any_keywords": ["毕业资格审核", "毕业审核", "审核材料"],
        "requires_action": true
      },
      "outputs": {
        "dimension": "risk",
        "hit_type": "keyword",
        "weight": 0.07,
        "candidate_categories": ["graduation"],
        "urgency_level": "high",
        "risk_level": "high",
        "emit_match": false
      },
      "version": "v1"
    },
    {
      "rule_id": "rule_student_assistant_audience",
      "rule_name": "学生助理招聘受众识别",
      "scene": "rule_engine",
      "enabled": true,
      "priority": 60,
      "conditions": {
        "any_keywords": ["学生助理", "勤工助学"],
        "profile_any": {
          "degree_level": ["undergraduate", "graduate", "master", "doctoral", "phd"]
        }
      },
      "outputs": {
        "dimension": "audience",
        "hit_type": "profile_match",
        "weight": 0.45,
        "candidate_categories": ["student_opportunity"],
        "signals": {
          "audience": ["student"]
        },
        "explanation": "命中学生岗位招聘受众",
        "emit_match": false
      },
      "version": "v1"
    },
    {
      "rule_id": "rule_student_assistant_action",
      "rule_name": "学生助理招聘动作识别",
      "scene": "rule_engine",
      "enabled": true,
      "priority": 55,
      "conditions": {
        "any_keywords": ["招聘", "招募", "报名"],
        "action_keywords": ["报名", "应聘"]
      },
      "outputs": {
        "dimension": "action",
        "hit_type": "keyword",
        "weight": 0.25,
        "candidate_categories": ["student_opportunity"],
        "action_required": true,
        "urgency_level": "high",
        "risk_level": "high",
        "signals": {
          "action_keywords": ["报名", "应聘"]
        },
        "explanation": "命中学生岗位报名动作",
        "emit_match": true
      },
      "version": "v1"
    },
    {
      "rule_id": "rule_open_opportunity_guard",
      "rule_name": "开放机会候选保护带",
      "scene": "rule_engine",
      "enabled": true,
      "priority": 45,
      "conditions": {
        "any_keywords": ["创新创业短课", "通识课", "公开课", "开放课", "研习营", "夏令营", "讲座", "工作坊"]
      },
      "outputs": {
        "dimension": "general",
        "hit_type": "keyword",
        "weight": 0.0,
        "candidate_categories": ["open_opportunity"],
        "required_profile_facets": ["identity_core"],
        "explanation": "命中开放机会候选保护带",
        "emit_match": false
      },
      "version": "v1"
    }
  ]
}
